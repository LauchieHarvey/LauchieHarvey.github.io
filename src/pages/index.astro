---
import Sphere from '../components/Sphere.astro';
import Layout from '../layouts/Layout.astro';
import LinkedIn from '../components/Icons/LinkedIn.astro';
import Github from '../components/Icons/Github.astro';
import ButtonCopyEmail from '../components/ButtonCopyEmail';

import "./index.css";
---

<Layout>
		<section id="hero-section">
			<h1>Lauchie Harvey - Software Developer</h1>

			<div class="hero-content-container">
				<Sphere/>

				<div class="copy-container">
					<p class="opaque">Full stack web developer with <b>5+ years of experience</b>.
						<br/>
						I love solving UX problems to improve the lives of my users.
					</p>

					<div class="cta-container">
						<ButtonCopyEmail client:load/>

						<div class="social-links">
							<a href="https://linkedin.com" title="LinkedIn"><LinkedIn/></a>

							<a href="https://github.com" title="GitHub"><Github/></a>
						</div>
					</div>
				</div>
			</div>

		</section>
</Layout>

<style>
	h1 {
		font-size: 3rem;
	}

	.hero-content-container {
		display: flex;
		flex-direction: column;
		justify-content: space-around;

		@media screen and (min-width: 700px) {
			flex-direction: row;
			position: relative;
			top: 50%;
			transform: translateY(-100%);
		}
	}

	.copy-container {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.copy-container p {
		font-size: 1.5rem;
	}

	.cta-container {
		display: flex;
		justify-content: space-between;
	}

	.cta-container .social-links {
		display: flex;
		gap: 0.8rem;
	}

	.cta-container .social-links a {
		position: relative;
		display: block;
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		text-decoration: none;
		color: var(--primary-text);
		background-color: var(--primary-color-dark);
		transition: scale 0.2s ease;
	}

	.cta-container .social-links a:hover {
		scale: 1.2;
	}

</style>
